%%{ init: { "theme": "default" } }%%
%% Module/port/adapter seam graph. s001 read layer DELIVERED (2026-06-09) — all
%% nodes stable. Nodes are seams (modules / ports / adapters), NOT every class.
%% Edges are the ACTUAL runtime routing/import paths on trunk.
graph TD
    %% --- Composition seam (UC6 owns; mounts every router via extraRouters) ---
    APP["app.js — createApp({repoRoot, extraRouters, allowedOrigin})<br/>CORS (localhost:5173 only) + app-level read-only guard (405)<br/>mounts UC1 + extraRouters under /api"]:::stable
    COMPOSE["compose.js — buildServerApp({repoRoot})<br/>UC6 composition root: builds watcher + UC1-UC5 routers<br/>returns {app, watcher}"]:::stable
    SERVER["server.js — bootstrap<br/>(UC6: uses buildServerApp; owns watcher.stop()+server.close() on SIGTERM/SIGINT)"]:::stable
    REPOROOT["repoRoot.js — resolveRepoRoot()"]:::stable

    %% --- UC1-UC4 adapters + parsers (on trunk, stable for this UC) ---
    R_PROJ["routes/projects.js (UC1 adapter)"]:::stable
    R_ITEMS["routes/items-queues.js (UC2 adapter)"]:::stable
    R_DORA["routes/dora.js (UC3 adapter)"]:::stable
    R_SLICE["routes/slices.js (UC4 adapter)"]:::stable
    P_PROJ["parsers/project-registry.js"]:::stable
    P_CSV["parsers/csv.js"]:::stable
    P_FILE["parsers/file-reader.js"]:::stable

    %% --- UC5 file-watch live-refresh ---
    WATCH["watcher.js — file-watch ADAPTER<br/>port: subscribe(fn)->unsub / ready() / stop()<br/>(chokidar isolated here)"]:::stable
    R_EVENTS["routes/events.js — SSE adapter<br/>GET /api/events (injected watcher port)"]:::stable

    %% Composition edges (adapters depend on domain; never reverse)
    APP --> R_PROJ
    APP --> REPOROOT
    R_PROJ --> P_PROJ
    R_ITEMS --> P_CSV
    R_DORA --> P_FILE
    R_SLICE --> P_FILE

    %% UC6 ACTUAL runtime routing path (realised this UC):
    %% server.js calls buildServerApp (compose.js). compose.js constructs the
    %% watcher, builds the UC2-UC5 routers, and passes them via extraRouters into
    %% createApp; createApp mounts UC1 + every extraRouter under /api and applies
    %% CORS + the read-only guard. server.js owns the watcher's stop() and the
    %% http server.close() on SIGTERM/SIGINT. The events router subscribes to the
    %% watcher port and imports NO chokidar.
    SERVER -->|buildServerApp| COMPOSE
    COMPOSE -->|createApp with extraRouters| APP
    COMPOSE -->|constructs| WATCH
    COMPOSE -->|builds UC2 router| R_ITEMS
    COMPOSE -->|builds UC3 router| R_DORA
    COMPOSE -->|builds UC4 router| R_SLICE
    COMPOSE -->|builds UC5 router, injects watcher port| R_EVENTS
    SERVER -->|owns watcher.stop on shutdown| WATCH
    APP -->|mounts extraRouters incl. UC2-UC5| R_ITEMS
    APP -->|mounts extraRouters| R_DORA
    APP -->|mounts extraRouters| R_SLICE
    APP -->|mounts extraRouters incl. events| R_EVENTS
    R_EVENTS -->|subscribes to port| WATCH

    %% --- s002 SPA seam (CHK-2). S2-UC1 scaffold: app shell + API client adapter.
    %% The SPA half talks to the read layer ONLY through the HTTP API (the boundary
    %% is the network, not an import) — so SPA_CLIENT depends on the deployed :3001
    %% surface (R_PROJ/R_ITEMS/R_DORA/R_EVENTS routes), drawn as a runtime call edge.
    %% S2-UC2..6 attach to SPA_MAIN/SPA_CLIENT, not to each other. ---
    SPA_CLIENT["src/app/src/api/client.js — SPA API ADAPTER (S2-UC1)<br/>only module knowing :3001 base URL + endpoint shapes<br/>getActive/getProjects/getQueues/getPolicy/getBaseline/subscribeEvents<br/>fail-soft: null on net/HTTP/parse error"]:::s002changed
    SPA_APP["src/app/src/App.jsx — app shell (S2-UC1)<br/>banner + main landmark = composition slot + build-sha stamp"]:::s002changed
    SPA_MAIN["src/app/src/main.jsx — Preact entry (S2-UC1)<br/>WIRING SEAM: mounts App; UC3 mounts MapContainer as App child here"]:::s002changed

    %% --- S2-UC2 state layer (domain) + S2-UC3 render (REALISED this UC) ---
    %% main.jsx mounts MapContainer as the App child (its one allowed edit to the
    %% seam). MapContainer loads the QueueState[] from the UC2 state layer and
    %% hands it to the pure PipelineMap render. PipelineMap touches NO fetch — it
    %% is a pure function of QueueState[] (data-status exposed as the UC4 badge
    %% hook). Tokens stylesheet seeded (design-system.md). UC2's state layer
    %% depends on SPA_CLIENT (the API adapter), never the reverse.
    SPA_STATE["src/app/src/state/queues.js — queue state layer (S2-UC2, domain)<br/>initQueueState() -> QueueState[] {name,length,min,wip,status}"]:::stable
    SPA_CONTAINER["src/app/src/components/MapContainer.jsx — data→render container (S2-UC3)<br/>loads initQueueState() on mount; fail-soft → empty state"]:::s002changed
    SPA_PIPELINE["src/app/src/components/PipelineMap.jsx (+ QueueBox, FlowArrow) — render (S2-UC3)<br/>pure fn of QueueState[]; region 'Pipeline map'; forward row + rework loop<br/>data-status hook for UC4; data-constraint='false' seed for UC5; aria-hidden SVG arrows"]:::s002changed
    SPA_TOKENS["src/app/src/styles/tokens.css — design tokens (S2-UC3 seed)"]:::s002changed

    %% --- S2-UC4 buffer-state badge (REALISED this UC) ---
    %% QueueBox now mounts BufferStateIndicator(status); it renders the starving
    %% (▽+text) / over-WIP (△+text) badge or NOTHING when ok. A11Y-5 redundant
    %% cue (icon + visible text + colour token, never colour-only). Pure fn of
    %% the domain status value; touches no fetch/CSV. Imports its own stylesheet.
    SPA_BADGE["src/app/src/components/BufferStateIndicator.jsx — buffer-state badge (S2-UC4)<br/>pure fn of status; data-testid='state-badge'; ▽/△ aria-hidden icon + visible text<br/>redundant --c-state-* colour token (A11Y-5); ok → null"]:::s002changed

    SPA_MAIN -->|renders| SPA_APP
    SPA_MAIN -->|mounts as App child| SPA_CONTAINER
    SPA_MAIN -->|imports| SPA_TOKENS
    SPA_CONTAINER -->|loads QueueState[]| SPA_STATE
    SPA_CONTAINER -->|renders| SPA_PIPELINE
    SPA_PIPELINE -->|mounts badge in QueueBox| SPA_BADGE
    SPA_BADGE -->|@import| SPA_TOKENS
    SPA_PIPELINE -->|@import| SPA_TOKENS
    SPA_STATE -->|getActive/getQueues/getPolicy| SPA_CLIENT
    SPA_CLIENT -.->|HTTP GET :3001/api/active,/projects| R_PROJ
    SPA_CLIENT -.->|HTTP GET :3001/api/projects/:id/queues/:q| R_ITEMS
    SPA_CLIENT -.->|HTTP GET :3001/api/dora/baseline| R_DORA
    SPA_CLIENT -.->|EventSource :3001/api/events| R_EVENTS

    classDef stable fill:#eee,stroke:#999,color:#000
    classDef delivered fill:#d5f5e3,stroke:#1e8449,color:#000
    classDef s002changed fill:#3a2233,stroke:#d96c8f,stroke-width:2px,color:#fff
