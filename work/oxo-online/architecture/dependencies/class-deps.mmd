%% oxo-online class/seam dependency graph — FIRST EDITION (s006, process §12a)
%% Seam-level: modules / domain-defined ports / adapters — NOT every class.
%% Engineer-owned (co-owned with architect+product). Edges = a module depending
%% on another module or implementing a port. Direction: adapters depend on
%% domain; domain depends on nothing concrete (hexagonal, §41).
%%
%% classDef `changed` marks THIS slice's (s006) new/redirected nodes & edges —
%% the tester's test-plan input. Marks are cleared ONLY at slice delivery, after
%% the tester has consumed them.
%%
%% R1.1 (this commit): CREATE first edition. Domain + port nodes are introduced
%% by s006, so they are marked changed. Adapter/handler/spa nodes are declared
%% (so consumers and the tester can see the intended seams) and marked changed as
%% their implementing edges land in their own steps (R2.1, R3.x, R5.1, R4.1).

flowchart TD

  %% ---- s006 move flow: DOMAIN centre (UC1) ----
  domainMove["domain-move<br/>move/move.ts — applyMove(board,turn,square,role,status)<br/>PURE: validate + apply + win/draw. Zero SDK/transport."]:::changed

  %% ---- DOMAIN-defined ports (move/ports.ts) ----
  portGameStore["port-game-store<br/>GameStorePort — getGame(gameId), applyMoveWrite (CAS)"]:::changed
  portRelay["port-relay<br/>RelayPort — postToConnections (2 bound conns)"]:::changed
  %% GATE-AMEND 2026-06-07: port-game-lookup (findGameByConnection / Connections
  %% Scan) is DEAD — it would widen S5. Move authorizes via getGame(gameId) +
  %% connectionId-vs-stored-binding match. Node removed; no edges to it.

  %% ---- ADAPTERS + handler (declared; implementing edges land per step) ----
  wsMoveHandler["ws-move-handler<br/>ws/move-handler.ts (UC3) — parse, getGame(gameId),<br/>bind identity by connectionId, call domain, write, relay"]:::changed
  adapterGamesDdb["adapter-games-ddb<br/>ws/adapters/games-ddb.ts (UC2) — conditional UpdateItem CAS"]:::changed
  adapterRelayMgmt["adapter-relay-mgmt<br/>ws/adapters/relay-mgmt.ts (UC3) — @connections POST"]:::changed
  adapterLocalStore["adapter-local-store<br/>src/app/local/adapters/local-store.ts (UC5) — in-memory CAS"]:::changed
  adapterLocalRelay["adapter-local-relay<br/>src/app/local/adapters/local-relay.ts (UC5) — records posts"]:::changed
  spaOnlineMove["spa-online-move<br/>src/app/src/game (UC4) — move-send + render-on-broadcast<br/>OnlineBoard(controlled) + GameRoot move loop, behind uc4Enabled flag"]:::changed

  %% SPA WS client transport seam (socket.ts GameSocket/GameSocketFactory).
  spaWsClient["spa-ws-client<br/>src/app/src/game/socket.ts — GameSocket seam<br/>{action:'move'} out; board-update/game-over in"]:::changed

  %% ---- Edges ----
  %% R2.1: games-ddb adapter implements the Games store port.
  adapterGamesDdb -.->|implements| portGameStore
  linkStyle 0 stroke:#d50000,stroke-width:3px;

  %% R4.1: the SPA online-move flow sends moves and renders broadcasts over the
  %% WS client transport seam (server-authoritative).
  spaOnlineMove -->|sends move / renders broadcast| spaWsClient
  linkStyle 1 stroke:#d50000,stroke-width:3px;

  %% R5.1 (this commit): UC5 local adapters implement the SAME domain ports the
  %% cloud adapters implement; the local move-handler drives the real domain.
  adapterLocalStore -.->|implements| portGameStore
  linkStyle 2 stroke:#d50000,stroke-width:3px;
  adapterLocalRelay -.->|implements| portRelay
  linkStyle 3 stroke:#d50000,stroke-width:3px;

  %% R3.1 (this commit): the UC3 move handler depends on the domain + the store
  %% and relay ports (NO game-lookup port — GATE-AMEND). It reads the game by
  %% gameId via port-game-store and binds identity by connectionId in-handler.
  wsMoveHandler -->|applyMove| domainMove
  linkStyle 4 stroke:#d50000,stroke-width:3px;
  wsMoveHandler -->|getGame + applyMoveWrite| portGameStore
  linkStyle 5 stroke:#d50000,stroke-width:3px;
  wsMoveHandler -->|board-update / game-over| portRelay
  linkStyle 6 stroke:#d50000,stroke-width:3px;

  %% R3.3 (this commit): the @connections relay adapter implements the relay port.
  adapterRelayMgmt -.->|implements| portRelay
  linkStyle 7 stroke:#d50000,stroke-width:3px;

  %% ==== s007 disconnect (UC1) — appended; classDef changed marks this slice ====
  %% UC1-S1: the Connections store port is extended with getConnection (the new
  %% $disconnect read seam). connectionId IS the identity (S1) — single GetItem of
  %% the connection's OWN row, no Query/Scan.
  portConnectionStore["port-connection-store<br/>ConnectionStorePort (move/ports.ts) — getConnection(connectionId), deleteConnection"]:::s007changed

  %% UC1-S2/S3: the pure $disconnect decision + the handler that orchestrates over
  %% the three ports (connection store, game store, relay) + the pure decision.
  domainDisconnect["domain-disconnect<br/>ws/disconnect/decide.ts — decideDisconnect(disconnectingId, gameItem)<br/>PURE: active→abandon+notify-survivor; terminal/waiting/missing→no-op"]:::s007changed
  wsDisconnectHandler["ws-disconnect-handler<br/>ws/disconnect-handler.ts (UC1) — getConnection→getGame→decide,<br/>conditional abandon (CAS), 1 survivor post, DeleteItem in all branches"]:::s007changed

  %% UC1-S4: the cloud Connections adapter implements the new port over DynamoDB
  %% GetItem + DeleteItem (backed by the UC2 Connections:GetItem grant — S5).
  adapterConnectionsDdb["adapter-connections-ddb<br/>ws/adapters/connections-ddb.ts (UC1) — GetItem + DeleteItem only (S5 pin)"]:::s007changed
  adapterLocalConnStore["adapter-local-connection-store<br/>src/app/local/adapters/local-connection-store.ts (UC1) — in-memory binding"]:::s007changed

  %% UC1-S1 edge: cloud + local adapters implement the new port.
  adapterConnectionsDdb -.->|implements| portConnectionStore
  linkStyle 8 stroke:#1565c0,stroke-width:3px;
  adapterLocalConnStore -.->|implements| portConnectionStore
  linkStyle 9 stroke:#1565c0,stroke-width:3px;

  %% UC1-S3 edges: the disconnect handler depends on the pure decision + all three
  %% ports (connection store to resolve identity, game store to abandon, relay to
  %% notify the one survivor).
  wsDisconnectHandler -->|decideDisconnect| domainDisconnect
  linkStyle 10 stroke:#1565c0,stroke-width:3px;
  wsDisconnectHandler -->|getConnection + deleteConnection| portConnectionStore
  linkStyle 11 stroke:#1565c0,stroke-width:3px;
  wsDisconnectHandler -->|getGame + abandonGame| portGameStore
  linkStyle 12 stroke:#1565c0,stroke-width:3px;
  wsDisconnectHandler -->|opponent-disconnected post| portRelay
  linkStyle 13 stroke:#1565c0,stroke-width:3px;

