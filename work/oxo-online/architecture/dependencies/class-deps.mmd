%% oxo-online class/seam dependency graph — FIRST EDITION (s006, process §12a)
%% Seam-level: modules / domain-defined ports / adapters — NOT every class.
%% Engineer-owned (co-owned with architect+product). Edges = a module depending
%% on another module or implementing a port. Direction: adapters depend on
%% domain; domain depends on nothing concrete (hexagonal, §41).
%%
%% classDef `changed` marks THIS slice's (s006) new/redirected nodes & edges —
%% the tester's test-plan input. Marks are cleared ONLY at slice delivery, after
%% the tester has consumed them.
%%
%% R1.1 (this commit): CREATE first edition. Domain + port nodes are introduced
%% by s006, so they are marked changed. Adapter/handler/spa nodes are declared
%% (so consumers and the tester can see the intended seams) and marked changed as
%% their implementing edges land in their own steps (R2.1, R3.x, R5.1, R4.1).

flowchart TD

  %% ---- s006 move flow: DOMAIN centre (UC1) ----
  domainMove["domain-move<br/>move/move.ts — applyMove(board,turn,square,role,status)<br/>PURE: validate + apply + win/draw. Zero SDK/transport."]:::changed

  %% ---- DOMAIN-defined ports (move/ports.ts) ----
  portGameStore["port-game-store<br/>GameStorePort — getGame, applyMoveWrite (CAS)"]:::changed
  portRelay["port-relay<br/>RelayPort — postToConnections (2 bound conns)"]:::changed
  portGameLookup["port-game-lookup<br/>GameLookupByConnectionPort — findGameByConnection"]:::changed

  %% ---- ADAPTERS + handler (declared; implementing edges land per step) ----
  wsMoveHandler["ws-move-handler<br/>ws/move-handler.ts (UC3) — parse, bind identity,<br/>call domain, write, relay"]
  adapterGamesDdb["adapter-games-ddb<br/>ws/adapters/games-ddb.ts (UC2) — conditional UpdateItem CAS"]:::changed
  adapterRelayMgmt["adapter-relay-mgmt<br/>ws/adapters/relay-mgmt.ts (UC3) — @connections POST"]
  adapterLocalStore["adapter-local-store<br/>src/app/local/adapters/local-store.ts (UC5) — in-memory CAS"]:::changed
  adapterLocalRelay["adapter-local-relay<br/>src/app/local/adapters/local-relay.ts (UC5) — records posts"]:::changed
  spaOnlineMove["spa-online-move<br/>src/app/src/game (UC4) — move-send + render-on-broadcast<br/>OnlineBoard(controlled) + GameRoot move loop, behind uc4Enabled flag"]:::changed

  %% SPA WS client transport seam (socket.ts GameSocket/GameSocketFactory).
  spaWsClient["spa-ws-client<br/>src/app/src/game/socket.ts — GameSocket seam<br/>{action:'move'} out; board-update/game-over in"]:::changed

  %% ---- Edges ----
  %% R2.1: games-ddb adapter implements the Games store port.
  adapterGamesDdb -.->|implements| portGameStore
  linkStyle 0 stroke:#d50000,stroke-width:3px;

  %% R4.1: the SPA online-move flow sends moves and renders broadcasts over the
  %% WS client transport seam (server-authoritative).
  spaOnlineMove -->|sends move / renders broadcast| spaWsClient
  linkStyle 1 stroke:#d50000,stroke-width:3px;

  %% R5.1 (this commit): UC5 local adapters implement the SAME domain ports the
  %% cloud adapters implement; the local move-handler drives the real domain.
  adapterLocalStore -.->|implements| portGameStore
  linkStyle 2 stroke:#d50000,stroke-width:3px;
  adapterLocalRelay -.->|implements| portRelay
  linkStyle 3 stroke:#d50000,stroke-width:3px;

  %% ---- Edges land in their own steps (not yet drawn): ----
  %% R3.1: wsMoveHandler --> domainMove / portGameStore / portRelay / portGameLookup
  %% R3.3: adapterRelayMgmt -.implements.-> portRelay

  classDef changed fill:#fff3e0,stroke:#d50000,stroke-width:3px,color:#000;
  classDef stable fill:#e8f4e8,stroke:#2e7d32,color:#000;
