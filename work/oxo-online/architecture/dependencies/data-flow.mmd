%% oxo-online runtime data-flow — s005-h3 edition (process §12a)
%% Platform GATES are explicit nodes. Non-obvious platform semantics are named ON the node.
%% This file is the TESTER's planning input. classDef changed marks THIS slice's (s008) delta.
%% Granularity: module / gate level (coarse). Built scope only (deferred items are NOT drawn).
%% s007 marks: the $disconnect path becomes REAL (abandon+notify+clean up) and the
%% CloudFront WAF gate gains the oxo-test-runner-ips IP-set scope-down annotation (IMP-008).
%% s005-h3 (delta 009, OI-3): code uniqueness is now STORAGE-ENFORCED. NEW node `codes`
%% (reservation table) + NEW edge gamefn -> codes (conditional PutItem reserve). The create
%% path reserves the code (attribute_not_exists CAS) BEFORE the Games PutItem; collision =>
%% bounded server-side retry (<=5) then 5xx (never a wrong code). Join/lookup path UNCHANGED
%% (still Games code-index; codes is write-time gate only). Client contract UNCHANGED.
%% classDef changed marks THIS slice's (s005-h3) delta: codes node, gamefn->codes edge, gamefn node.

flowchart TD

  %% ---- Edge / SPA path (HTTPS) ----
  player(["Player browser / SPA"]):::actor
  cfwaf["CloudFront + WAFv2 WebACL (global, us-east-1 scope)<br/>GATE: rate 100/5min per IP + IP-reputation, DEFAULT-ALLOW.<br/>WAF rate rule = SLIDING 300s window, ~30s eval cadence + propagation<br/>(sustained traffic trips it, a short burst can slip through).<br/>Block=403; CF maps 403 to index.html (keep block code DISJOINT, e.g. 429).<br/>SPA-FALLBACK: CustomErrorResponses 403 AND 404 -> 200 + /index.html (ttl 0);<br/>S3-OAC 403s a MISSING key, so an unknown path (e.g. /join/&lt;code&gt;) boots the SPA<br/>and React Router routes it CLIENT-SIDE. (s008 deep-link relies on this EXISTING rule;<br/>OI-31: WAF block code MUST stay disjoint from this list or blocks become invisible.)<br/>s007/IMP-008: rate rule scope-down = NOT(IPSet oxo-test-runner-ips) so RUNNER<br/>IPs bypass the COUNT (Block+limit UNCHANGED for all other IPs). IP set is<br/>TRANSIENT: added per smoke run, removed by trap, drained <=24h. Deploy-role mutate only."]:::gate
  s3[("S3 web bucket<br/>private, OAC-only; serves SPA + OXO_CONFIG runtime cfg incl. wsUrl + buildSha")]:::store
  httpapi["API Gateway HTTP API v2<br/>GATE: route POST /games only. NO stage WAF (CF WAF covers /api/*).<br/>NOT WAFv2-associable (v2 API). TLS1.2+."]:::gate
  gamefn["oxo-game-fn (Lambda)<br/>create-game: RESERVE code (conditional PutItem Codes, attribute_not_exists, <=5 retries) then PutItem Games;<br/>collision => fresh code retry; 5 exhausted => 5xx WE own (reason:code-reservation-exhausted), never a wrong code;<br/>mints host wsToken (HMAC, 60s exp). Client contract {gameId,code,wsToken} UNCHANGED. (s005-h3 CHANGED)"]:::compute
  codes[("DynamoDB Codes (reservation, s005-h3)<br/>PK=code; conditional PutItem attribute_not_exists(code) = single-item CAS =><br/>at-most-one live reservation per code (storage-enforced uniqueness, no in-mem race).<br/>WRITE-TIME GATE ONLY — NOT on the join/lookup read path (join still uses Games code-index).<br/>ttl 24h, LAZY deletion (orphan reservation lingers but harmless: nothing reads Codes).<br/>SSE, on-demand, no GSI. Grant: oxo-game-fn PutItem on this ARN ONLY (no Delete/Get/Query/Scan).")]:::store
  secret["WS-token secret (SSM SecureString)<br/>HMAC key; read-scoped: oxo-game-fn mint + oxo-ws-auth-fn verify ONLY"]:::secret

  %% ---- WebSocket path (WSS, NOT via CloudFront) ----
  wsupgrade["WS upgrade to API Gateway WebSocket API v2<br/>GATE: NOT WAFv2-associable. Flood control = stage throttle 20/40<br/>(account/stage-level, NOT per-IP) + reserved-concurrency."]:::gate
  wsauth["$connect REQUEST authorizer = oxo-ws-auth-fn (Lambda)<br/>GATE: host wsToken XOR guest code; Allow/Deny via IAM-POLICY shape<br/>(REST-style principalId+policyDocument, NOT isAuthorized).<br/>NO result cache (WS authorizers reject AuthorizerResultTtlInSeconds - strike 4).<br/>IdentitySource OMITTED so authorizer runs UNCONDITIONALLY and does<br/>the either-or itself (listed sources are ANDed/pre-invocation-gated - strike 5, DEFECT-H2-002)."]:::gate
  attempts[("DynamoDB ConnectAttempts<br/>sourceIp to count. TTL 5min, LAZY deletion: expired item may still be<br/>readable up to ~48h after TTL, so per-IP budget is BEST-EFFORT, not exact.<br/>SSE, on-demand.<br/>s007a EXEMPTION namespace: PK 'EXEMPT#&lt;ip&gt;', ttl=now+3600 (1h), no count.<br/>WRITTEN by oxo-deploy via waf-runner-ip.js (PutItem/DeleteItem, LeadingKeys EXEMPT#*)<br/>— SAME principal/tool as the WAF IP-set. NOT written by the authorizer.")]:::store
  wsfn["oxo-ws-fn (Lambda) — route dispatch on $request.body.action<br/>Routes: $connect / $disconnect(REAL s007) / register / join / move<br/>Validates + applies; runs ONLY after authorizer Allow.<br/>s007 $disconnect: GetItem(Connections, OWN connectionId) -> gameId; conditional<br/>UpdateItem Games status=active->abandoned (won/drawn guard); notify survivor; delete row.<br/>Idle: APIGW 10-min idle close fires the SAME $disconnect (no custom keepalive)."]:::compute
  conn[("DynamoDB Connections<br/>connectionId to gameId/role. TTL 2h, LAZY deletion (expired item lingers).<br/>SSE, on-demand.")]:::store
  games[("DynamoDB Games (+ code-index GSI)<br/>authoritative item: status, host/guestConnectionId, board, currentTurn,<br/>winner, version (optimistic-lock CAS), moveCount. TTL 24h, LAZY deletion.<br/>SSE, on-demand.")]:::store
  relay["@connections POST (API GW Management API)<br/>GATE: relay to the TWO bound connectionIds only (host+guest).<br/>No broadcast. 410 Gone if connection dead.<br/>s007: $disconnect notify = EXACTLY 1 POST to the survivor (0 on terminal/waiting);<br/>survivor GoneException -> swallow, NO retry storm (both gone)."]:::gate

  %% ---- Existing edges (built s001..s005-h2) ----
  player -->|"HTTPS load SPA + read OXO_CONFIG"| cfwaf
  cfwaf -->|"OAC origin fetch"| s3
  cfwaf -->|"routes /api/*"| httpapi
  player -->|"POST /api/games to gameId,code,wsToken"| cfwaf
  httpapi -->|"AWS_PROXY invoke"| gamefn
  gamefn -.->|"RESERVE code: conditional PutItem attribute_not_exists(code); ConditionalCheckFailed => retry fresh code (<=5) then 5xx (s005-h3 NEW)"| codes
  gamefn -->|"PutItem create (AFTER reserve succeeds)"| games
  gamefn -->|"read HMAC"| secret

  player -->|"direct WSS $connect wsToken|code (NOT via CloudFront)"| wsupgrade
  wsupgrade -->|"pre-invocation identity gate, then invoke"| wsauth
  wsauth -->|"verify wsToken"| secret
  wsauth -->|"GetItem code-index guest path"| games
  wsauth -->|"UpdateItem ADD per-IP budget"| attempts
  wsauth -.->|"s007a GATE: ONLY on over-threshold path, GetItem(EXEMPT#&lt;ip&gt;); exempt IFF ttl&gt;now (lazy-delete defence); waives RATE_LIMIT Deny ONLY, never validation; non-exempt IP STILL Denies; GetItem error -> Deny (fail-closed)"| attempts
  wsauth -->|"Allow IAM policy"| wsupgrade
  wsupgrade -->|"AWS_PROXY invoke per message AFTER Allow"| wsfn
  wsfn -->|"register: conditional UpdateItem host slot"| games
  wsfn -->|"join: conditional UpdateItem to active + init board/currentTurn/version (s006)"| games
  wsfn -->|"Put/Delete connection"| conn
  wsfn -.->|"game-ready fan-out to 2 conns; payload now carries gameId so GUEST learns its lookup key for move (s006 AMEND 2026-06-07)"| relay
  relay -->|"game-ready / board-update / game-over"| player

  %% ---- s006 NEW data flow: move relay (CHANGED, dotted) ----
  %% AMEND 2026-06-07: move frame carries gameId as a NON-TRUSTED LOOKUP KEY (selects
  %% the Games item to read; NOT an identity/role claim). Authorization is the
  %% server-side match of the REAL requestContext.connectionId vs stored host/guest
  %% ConnectionId; forged gameId resolves a game the sender is not in -> reject, no
  %% write. This is why NO Connections-read edge is added on the move path (S5 intact).
  %% game-ready fan-out (line 44 / join.ts) must now also carry gameId so the GUEST
  %% (joins by code) can supply the lookup key.
  player -.->|"WS msg action=move, gameId(NON-TRUSTED lookup key), square (NEW)"| wsfn
  wsfn -.->|"GetItem(Games, body.gameId) read current board (already-granted read; key is client-supplied, authz still by connectionId match)"| games
  wsfn -.->|"move: atomic conditional UpdateItem CAS on status=active AND currentTurn=senderRole AND version=expected; SET board/turn/version+1 and on terminal status=won|drawn,winner (NEW)"| games
  wsfn -.->|"accepted move = EXACTLY 2 board-update POSTs (terminal <=4); rejected = 1 move-rejected POST, 0 writes (NEW)"| relay

  %% ---- s007 NEW data flow: $disconnect abandon + notify + clean up (CHANGED, dotted) ----
  %% Platform fires $disconnect with ONLY the disconnecting OWN connectionId (no gameId, no body).
  %% connectionId IS the identity (platform-set, unspoofable) -> NO force-abandon spoof path.
  %% New IAM grant: dynamodb:GetItem on Connections ONLY (read OWN row by PK; no Query/Scan).
  player -.->|"WS close / tab close / APIGW 10-min idle -> platform $disconnect (own connectionId, NO body) (s007 NEW)"| wsupgrade
  wsupgrade -.->|"$disconnect lifecycle invoke (post-Allow; authorizer does NOT re-run) (s007 NEW)"| wsfn
  wsfn -.->|"GetItem(Connections, OWN connectionId) -> gameId/role (s007 NEW GRANT: GetItem on Connections only)"| conn
  wsfn -.->|"GetItem(Games, gameId) read status + host/guest connIds (already-granted) (s007 NEW)"| games
  wsfn -.->|"conditional UpdateItem status=active->abandoned, CONDITION status=active (won/drawn guard); ConditionalCheckFailed = no write, swallow (s007 NEW)"| games
  wsfn -.->|"notify survivor: EXACTLY 1 opponent-disconnected POST (0 on terminal/waiting); 410 = swallow, no retry (s007 NEW)"| relay
  wsfn -.->|"DeleteItem(Connections, OWN connectionId) ALL branches (already-granted); 2h TTL is backstop (s007 NEW)"| conn

